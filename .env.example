# ============================================================
# Application
# ============================================================
PUBLIC_IP=113.30.191.86
COMPOSE_PROJECT_NAME=optinetflow
NETWORK_NAME=optinetflow                 # Docker network shared across all services
CONTAINER_NAME=optinetflow_nest
PORT=3333                                # NestJS application port
PLAYGROUND_ENABLED=true                  # GraphQL playground (disable in production)
GRAPHQL_INTROSPECTION=true               # GraphQL introspection (disable in production)
NODE_ENV=development                     # development | production

# ============================================================
# Security
# ============================================================
JWT_ACCESS_SECRET=                       # Secret for signing JWT access tokens (generate: openssl rand -hex 32)
JWT_REFRESH_SECRET=                      # Secret for signing JWT refresh tokens (generate: openssl rand -hex 32)
ACCESS_TOKEN_EXPIRE_IN=7d                # Access token TTL (e.g., 15m, 1h, 7d)
OTP_EXPIRATION=2                         # OTP validity in minutes
SMS_IR_API_KEY=                          # SMS.ir API key for OTP delivery

# ============================================================
# PostgreSQL
# ============================================================
DB_CONTAINER_NAME=pg_optinetflow
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFER=1.5GB
POSTGRES_USER=optinetflow_develop_user
POSTGRES_PASSWORD=optinetflow_develop_pass
POSTGRES_DB=optinetflow_develop_db
DB_HOST=127.0.0.1
DB_PORT=5432
DB_SCHEMA=public
POSTGRES_DB_PERSIST_PATH=/root/volume/postgres-data  # Host path for PostgreSQL data persistence

# ============================================================
# PgBouncer (Connection Pooling)
# ============================================================
PGBOUNCER_CONTAINER_NAME=optinetflow_pgbouncer
PGBOUNCER_PORT=6432

# Prisma connects through PgBouncer with pgbouncer=true (disables prepared statements)
DATABASE_URL=postgresql://optinetflow_develop_user:optinetflow_develop_pass@127.0.0.1:6432/optinetflow_develop_db?pgbouncer=true&pool_timeout=20

# ============================================================
# MinIO (S3-Compatible Object Storage)
# ============================================================
MINIO_CONTAINER_NAME=minio_optinetflow
MINIO_PUBLIC_URL=http://127.0.0.1:9000/optinetflow  # Public URL for file access
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_DASHBOARD_PORT=9001
MINIO_ROOT_USER=optinetflow_develop_user
MINIO_ROOT_PASSWORD=optinetflow_develop_pass
MINIO_REGION_NAME=us-newyork
MINIO_BUCKET=optinetflow
MINIO_PERSIST_PATH=/root/volume/minio-data           # Host path for MinIO data persistence

# ============================================================
# Telegram Bot
# ============================================================
# Bot tokens are configured per-brand in the Brand model.
# These are for development/testing only.
WEB_PANEL_URL=                           # Frontend URL for deep links in Telegram messages
BACKDOOR_PASS=                           # Development-only master password (MUST be empty in production)

# ============================================================
# Development & Backup Scripts
# ============================================================
DEV_BOT_TOKEN=                           # Telegram bot token for local development
DEV_BOT_USERNAME=                        # Bot username for local development
PROD_SSH_USER=                           # SSH user for production backup scripts
PROD_SSH_HOST=                           # SSH host for production backup scripts
PROD_DB_URL=                             # Production DATABASE_URL for backup scripts

# ============================================================
# Metabase (Analytics Dashboard)
# ============================================================
METABASE_PORT=6000
METABASE_DB_NAME=metabase_db
METABASE_DB_USER=metabase_db_user
METABASE_DB_PASSWORD=metabase_db_password
METABASE_DB_PORT=4432
METABASE_DB_PERSIST_PATH=/root/volume/metabase-db-data
